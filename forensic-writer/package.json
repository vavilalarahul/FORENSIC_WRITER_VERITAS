{
    "name": "forensic-writer-root",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "install-all": "npm install && cd server && npm install && cd ../client && npm install",
        "server": "cd server && npm run dev",
        "start": "node server/src/server.js",
        "client": "cd client && npm run dev",
        "dev": "concurrently \"npm run server\" \"npm run client\""
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    },
    "dependencies": {
        "axios": "^1.15.1",
        "bcrypt": "^6.0.0",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "jsonwebtoken": "^9.0.3",
        "mongoose": "^9.4.1",
        "nodemailer": "^8.0.5",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-router-dom": "^7.14.1"
    }
}
